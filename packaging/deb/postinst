#!/usr/bin/env bash
set -e

if ! id sigilbridge >/dev/null 2>&1; then
  useradd --system --home /var/lib/sigilbridge --shell /usr/sbin/nologin sigilbridge
fi

install -d -o sigilbridge -g sigilbridge -m 0750 /var/lib/sigilbridge
install -d -o sigilbridge -g sigilbridge -m 0750 /var/log/sigilbridge

if command -v systemctl >/dev/null 2>&1; then
  systemctl daemon-reload || true
fi
